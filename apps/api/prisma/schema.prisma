// Mallannapeta Kitchen — Production Schema
// PostgreSQL 16 · Prisma 6

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────── ENUMS ───────────────────

enum Role {
  OWNER
  MANAGER
  KITCHEN_STAFF
  CUSTOMER
}

enum OrderStatus {
  PENDING_PAYMENT
  CONFIRMED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  RAZORPAY
  COD
}

enum PaymentStatus {
  PENDING
  CAPTURED
  FAILED
  REFUNDED
  REFUND_PENDING
}

enum CouponType {
  FLAT
  PERCENT
}

enum AuthProvider {
  EMAIL
  GOOGLE
  PHONE
}

// ─────────────────── USERS / AUTH ───────────────────

model User {
  id                String    @id @default(cuid())
  email             String?   @unique
  phoneE164         String?   @unique @map("phone_e164")
  hashedPassword    String?   @map("hashed_password")
  googleId          String?   @unique @map("google_id")
  name              String?
  role              Role      @default(CUSTOMER)
  emailVerifiedAt   DateTime? @map("email_verified_at")
  phoneVerifiedAt   DateTime? @map("phone_verified_at")
  failedLoginCount  Int       @default(0) @map("failed_login_count")
  lockedUntil       DateTime? @map("locked_until")
  lastLoginAt       DateTime? @map("last_login_at")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  addresses              UserAddress[]
  refreshTokens          RefreshToken[]
  passwordResetTokens    PasswordResetToken[]
  cart                   Cart?
  orders                 Order[]
  pushSubscriptions      PushSubscription[]
  notificationPreference NotificationPreference?
  couponRedemptions      CouponRedemption[]
  auditLogs              AuditLog[]
  orderStatusHistory     OrderStatusHistory[]

  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

model RefreshToken {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  tokenHash   String    @unique @map("token_hash")
  familyId    String    @map("family_id")
  userAgent   String?   @map("user_agent")
  ipAddress   String?   @map("ip_address")
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  replacedBy  String?   @map("replaced_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model PhoneOtp {
  id         String    @id @default(cuid())
  phoneE164  String    @map("phone_e164")
  otpHash    String    @map("otp_hash")
  purpose    String    @default("login") // login | verify_phone | reset
  attempts   Int       @default(0)
  maxAttempts Int      @default(5) @map("max_attempts")
  expiresAt  DateTime  @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([phoneE164, purpose])
  @@index([expiresAt])
  @@map("phone_otps")
}

// ─────────────────── ADDRESSES & SERVICE AREA ───────────────────

model UserAddress {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  label     String    // Home, Work, Other
  line1     String
  line2     String?
  landmark  String?
  city      String
  pincode   String
  latitude  Decimal?  @db.Decimal(10, 7)
  longitude Decimal?  @db.Decimal(10, 7)
  isDefault Boolean   @default(false) @map("is_default")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deletedAt])
  @@index([pincode])
  @@map("user_addresses")
}

model ServiceablePincode {
  id        String    @id @default(cuid())
  pincode   String    @unique
  areaName  String?   @map("area_name")
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([isActive, deletedAt])
  @@map("serviceable_pincodes")
}

// ─────────────────── MENU ───────────────────

model Category {
  id           String    @id @default(cuid())
  name         String
  nameTe       String?   @map("name_te")
  slug         String    @unique
  imageUrl     String?   @map("image_url")
  icon         String?
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  menuItems MenuItem[]

  @@index([isActive, deletedAt])
  @@index([displayOrder])
  @@map("categories")
}

model MenuItem {
  id                       String    @id @default(cuid())
  categoryId               String    @map("category_id")
  name                     String
  nameTe                   String?   @map("name_te")
  slug                     String    @unique
  description              String?   @db.Text
  descriptionTe            String?   @map("description_te") @db.Text
  imageUrl                 String?   @map("image_url")
  isVeg                    Boolean   @default(false) @map("is_veg")
  isAvailable              Boolean   @default(true) @map("is_available")
  isBestseller             Boolean   @default(false) @map("is_bestseller")
  isSundaySpecialCandidate Boolean   @default(false) @map("is_sunday_special_candidate")
  // True for the hidden backing item auto-created by a standalone Sunday Special.
  // These never appear in the regular menu — they exist only so a Sunday Special
  // can flow through the normal cart/checkout/order pipeline.
  isSundaySpecialOnly      Boolean   @default(false) @map("is_sunday_special_only")
  displayOrder             Int       @default(0) @map("display_order")
  deletedAt                DateTime? @map("deleted_at")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  category        Category           @relation(fields: [categoryId], references: [id])
  variants        MenuItemVariant[]
  addons          MenuItemAddon[]
  cartItems       CartItem[]
  orderItems      OrderItem[]
  sundaySpecials  SundaySpecial[]

  @@index([categoryId, isAvailable, deletedAt])
  @@index([isBestseller])
  @@index([deletedAt])
  @@map("menu_items")
}

model MenuItemVariant {
  id           String    @id @default(cuid())
  menuItemId   String    @map("menu_item_id")
  label        String    // "1 Person", "2 Persons", "1 KG"
  labelTe      String?   @map("label_te")
  price        Decimal   @db.Decimal(10, 2)
  displayOrder Int       @default(0) @map("display_order")
  isAvailable  Boolean   @default(true) @map("is_available")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  menuItem   MenuItem    @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([menuItemId, deletedAt])
  @@map("menu_item_variants")
}

model MenuItemAddon {
  id          String  @id @default(cuid())
  menuItemId  String  @map("menu_item_id")
  label       String
  labelTe     String? @map("label_te")
  price       Decimal @db.Decimal(10, 2)
  isAvailable Boolean @default(true) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
  @@map("menu_item_addons")
}

// ─────────────────── SUNDAY SPECIAL ───────────────────

model SundaySpecial {
  id                 String   @id @default(cuid())
  menuItemId         String   @map("menu_item_id")
  weekStarting       DateTime @map("week_starting") @db.Date // multiple specials per Sunday allowed
  specialPrice       Decimal  @db.Decimal(10, 2) @map("special_price")
  bannerPhotoUrl     String?  @map("banner_photo_url")
  bannerHeadline     String?  @map("banner_headline")
  bannerHeadlineTe   String?  @map("banner_headline_te")
  description        String?  @db.Text
  descriptionTe      String?  @map("description_te") @db.Text
  isActive           Boolean  @default(true) @map("is_active")
  // Override: when true the special is orderable on ANY day, not just its Sunday.
  availableAnyDay    Boolean  @default(false) @map("available_any_day")
  notificationSentAt DateTime? @map("notification_sent_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([weekStarting, isActive])
  @@map("sunday_specials")
}

// ─────────────────── CART ───────────────────

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id         String   @id @default(cuid())
  cartId     String   @map("cart_id")
  menuItemId String   @map("menu_item_id")
  variantId  String?  @map("variant_id")
  qty        Int
  notes      String?
  addedAt    DateTime @default(now()) @map("added_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  cart     Cart             @relation(fields: [cartId], references: [id], onDelete: Cascade)
  menuItem MenuItem         @relation(fields: [menuItemId], references: [id])
  variant  MenuItemVariant? @relation(fields: [variantId], references: [id])

  @@unique([cartId, menuItemId, variantId])
  @@index([cartId])
  @@map("cart_items")
}

// ─────────────────── ORDERS ───────────────────

model Order {
  id                       String        @id @default(cuid())
  orderNumber              String        @unique @map("order_number")
  userId                   String        @map("user_id")
  status                   OrderStatus   @default(PENDING_PAYMENT)
  subtotal                 Decimal       @db.Decimal(10, 2)
  discount                 Decimal       @default(0) @db.Decimal(10, 2)
  deliveryFee              Decimal       @db.Decimal(10, 2) @map("delivery_fee")
  total                    Decimal       @db.Decimal(10, 2)
  paymentMethod            PaymentMethod @map("payment_method")
  customerNameSnapshot     String        @map("customer_name_snapshot")
  customerPhoneSnapshot    String        @map("customer_phone_snapshot")
  customerEmailSnapshot    String?       @map("customer_email_snapshot")
  addressSnapshot          Json          @map("address_snapshot")
  specialInstructions      String?       @map("special_instructions") @db.Text
  couponId                 String?       @map("coupon_id")
  couponCodeSnapshot       String?       @map("coupon_code_snapshot")
  estimatedDeliveryMinutes Int?          @map("estimated_delivery_minutes")
  idempotencyKey           String?       @unique @map("idempotency_key") // C1: prevents duplicate orders from one checkout attempt
  version                  Int           @default(0) // for optimistic concurrency

  // Lifecycle timestamps
  placedAt           DateTime  @default(now()) @map("placed_at")
  confirmedAt        DateTime? @map("confirmed_at")
  preparingAt        DateTime? @map("preparing_at")
  outForDeliveryAt   DateTime? @map("out_for_delivery_at")
  deliveredAt        DateTime? @map("delivered_at")
  cancelledAt        DateTime? @map("cancelled_at")
  cancelledReason    String?   @map("cancelled_reason")
  refundedAt         DateTime? @map("refunded_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user           User                 @relation(fields: [userId], references: [id])
  items          OrderItem[]
  statusHistory  OrderStatusHistory[]
  payment        Payment?
  coupon         Coupon?              @relation(fields: [couponId], references: [id])
  couponRedemption CouponRedemption?

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([placedAt])
  @@map("orders")
}

model OrderItem {
  id               String  @id @default(cuid())
  orderId          String  @map("order_id")
  menuItemId       String  @map("menu_item_id")
  variantId        String? @map("variant_id")
  itemSnapshot     Json    @map("item_snapshot")
  variantSnapshot  Json?   @map("variant_snapshot")
  addonsSnapshot   Json?   @map("addons_snapshot")
  qty              Int
  unitPrice        Decimal @db.Decimal(10, 2) @map("unit_price")
  lineTotal        Decimal @db.Decimal(10, 2) @map("line_total")
  createdAt        DateTime @default(now()) @map("created_at")

  order    Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem         @relation(fields: [menuItemId], references: [id])
  variant  MenuItemVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model OrderStatusHistory {
  id           String       @id @default(cuid())
  orderId      String       @map("order_id")
  fromStatus   OrderStatus? @map("from_status")
  toStatus     OrderStatus  @map("to_status")
  actorUserId  String?      @map("actor_user_id")
  notes        String?      @db.Text
  createdAt    DateTime     @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorUserId], references: [id])

  @@index([orderId, createdAt])
  @@map("order_status_history")
}

// ─────────────────── PAYMENTS ───────────────────

model Payment {
  id                  String        @id @default(cuid())
  orderId             String        @unique @map("order_id")
  method              PaymentMethod
  status              PaymentStatus @default(PENDING)
  amount              Decimal       @db.Decimal(10, 2)
  currency            String        @default("INR")
  razorpayOrderId     String?       @unique @map("razorpay_order_id")
  razorpayPaymentId   String?       @unique @map("razorpay_payment_id")
  razorpaySignature   String?       @map("razorpay_signature")
  refundId            String?       @map("refund_id")
  refundAmount        Decimal?      @db.Decimal(10, 2) @map("refund_amount")
  failureCode         String?       @map("failure_code")
  failureDescription  String?       @map("failure_description")
  webhookEvents       Json?         @map("webhook_events")
  capturedAt          DateTime?     @map("captured_at")
  refundedAt          DateTime?     @map("refunded_at")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("payments")
}

// ─────────────────── COUPONS ───────────────────

model Coupon {
  id                 String     @id @default(cuid())
  code               String     @unique
  description        String?
  type               CouponType
  value              Decimal    @db.Decimal(10, 2)
  minOrderValue      Decimal    @default(0) @db.Decimal(10, 2) @map("min_order_value")
  maxDiscount        Decimal?   @db.Decimal(10, 2) @map("max_discount")
  totalUsageLimit    Int?       @map("total_usage_limit")
  currentUsageCount  Int        @default(0) @map("current_usage_count")
  perUserLimit       Int        @default(1) @map("per_user_limit")
  validFrom          DateTime   @map("valid_from")
  validTo            DateTime   @map("valid_to")
  isActive           Boolean    @default(true) @map("is_active")
  deletedAt          DateTime?  @map("deleted_at")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  orders      Order[]
  redemptions CouponRedemption[]

  @@index([isActive, deletedAt])
  @@index([validFrom, validTo])
  @@map("coupons")
}

model CouponRedemption {
  id              String   @id @default(cuid())
  couponId        String   @map("coupon_id")
  userId          String   @map("user_id")
  orderId         String   @unique @map("order_id")
  discountApplied Decimal  @db.Decimal(10, 2) @map("discount_applied")
  createdAt       DateTime @default(now()) @map("created_at")

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([couponId, orderId])
  @@index([couponId, userId])
  @@map("coupon_redemptions")
}

// ─────────────────── PUSH NOTIFICATIONS ───────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model NotificationPreference {
  userId               String  @id @map("user_id")
  sundaySpecialAlerts  Boolean @default(true) @map("sunday_special_alerts")
  orderUpdates         Boolean @default(true) @map("order_updates")
  marketing            Boolean @default(false)
  updatedAt            DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ─────────────────── KITCHEN SETTINGS ───────────────────

model KitchenSettings {
  id                String   @id @default("settings") // singleton
  name              String   @default("Mallannapeta Kitchen")
  nameTe            String?  @default("మల్లన్నపేట కిచెన్") @map("name_te")
  isOpen            Boolean  @default(true) @map("is_open")
  openingHours      String   @default("10:00 AM – 9:00 PM") @map("opening_hours")
  openingHoursTe    String?  @default("ఉ. 10:00 – రా. 9:00") @map("opening_hours_te")
  contactPhone      String   @map("contact_phone")
  supportWhatsapp   String   @map("support_whatsapp")
  contactEmail      String   @map("contact_email")
  instagramUrl      String?  @map("instagram_url")
  minOrderValue     Decimal  @default(100) @db.Decimal(10, 2) @map("min_order_value")
  deliveryFee       Decimal  @default(40) @db.Decimal(10, 2) @map("delivery_fee")
  estimatedPrepMinutes Int   @default(45) @map("estimated_prep_minutes")
  closedMessage     String?  @map("closed_message")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("kitchen_settings")
}

// ─────────────────── AUDIT LOG ───────────────────

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?  @map("actor_user_id")
  action      String   // CREATE, UPDATE, DELETE, STATUS_CHANGE, REFUND, etc.
  entityType  String   @map("entity_type") // Order, MenuItem, User, etc.
  entityId    String   @map("entity_id")
  before      Json?
  after       Json?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────── WEBHOOK EVENTS (idempotency) ───────────────────

model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String   // razorpay
  eventId     String   @map("event_id") // provider-side event id
  eventType   String   @map("event_type")
  payload     Json
  processedAt DateTime? @map("processed_at")
  error       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([provider, eventId])
  @@index([provider, eventType])
  @@map("webhook_events")
}
